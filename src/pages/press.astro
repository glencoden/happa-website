---
import Layout from '../layouts/Layout.astro'
import TextPage from '../components/TextPage/TextPage'
import { requestService } from '../services/requestService'
import { assertData } from '../services/assertData'

const data = assertData(await requestService.getPressData(), 'press')
---

<Layout>
    <TextPage client:idle title={data.title} text={data.text} />
</Layout>
